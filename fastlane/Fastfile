# DeelMarkt Fastfile
#
# Lanes:
#   ios_screenshots      — generate + upload screenshots to App Store Connect
#   ios_metadata         — upload metadata only (no binary, no screenshots)
#   android_screenshots  — generate + upload screenshots to Play Console
#   android_metadata     — upload metadata only to Play Console
#   deliver_dry_run      — dry-run validation for both stores
#
# Required environment variables (set in GitHub Secrets or .env):
#   APPLE_ID             — Apple ID email
#   ITC_TEAM_ID          — App Store Connect team ID
#   ASC_API_KEY_JSON     — App Store Connect API key JSON (base64 or path)
#   GOOGLE_PLAY_JSON_KEY — Path to Google Play service account JSON key
#   ASC_DEMO_USER        — Demo reviewer account email (stored in 1Password)
#   ASC_DEMO_PASSWORD    — Demo reviewer account password (stored in 1Password)

fastlane_version "2.220.0"

default_platform(:ios)

# ─── iOS ───────────────────────────────────────────────────────────────────────

platform :ios do
  # Regenerate goldens + organise into fastlane/screenshots/ then upload.
  lane :ios_screenshots do
    _regenerate_screenshots
    deliver(
      api_key_path: ENV["ASC_API_KEY_JSON"],
      skip_metadata: true,
      skip_binary_upload: true,
      overwrite_screenshots: true,
      screenshots_path: "fastlane/screenshots",
      submit_for_review: false,
    )
    UI.success "iOS screenshots uploaded successfully"
  end

  # Upload metadata only — no binary, no screenshots.
  lane :ios_metadata do
    _require_demo_credentials
    deliver(
      api_key_path: ENV["ASC_API_KEY_JSON"],
      skip_screenshots: true,
      skip_binary_upload: true,
      skip_app_version_strings: false,
      metadata_path: "fastlane/metadata",
      app_review_information: _demo_review_information,
      force: true,
      submit_for_review: false,
    )
    UI.success "iOS metadata uploaded successfully"
  end

  # Dry-run: validates metadata + screenshots locally without uploading.
  lane :deliver_dry_run do
    _require_demo_credentials
    deliver(
      api_key_path: ENV["ASC_API_KEY_JSON"],
      skip_binary_upload: true,
      run_precheck_before_submit: true,
      precheck_default_rule_level: :warn,
      app_review_information: _demo_review_information,
      submit_for_review: false,
    )
    UI.success "deliver dry-run passed — Ready to submit"
  end
end

# ─── Android ───────────────────────────────────────────────────────────────────

platform :android do
  # Regenerate goldens + organise into fastlane/android/screenshots/ then upload.
  lane :android_screenshots do
    _regenerate_screenshots
    supply(
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"],
      package_name: "nl.deelmarkt.deelmarkt",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      track: "internal",
      screenshots_path: "fastlane/android/screenshots",
    )
    UI.success "Android screenshots uploaded successfully"
  end

  # Upload metadata only to Play Console.
  lane :android_metadata do
    supply(
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"],
      package_name: "nl.deelmarkt.deelmarkt",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_screenshots: true,
      metadata_path: "fastlane/android/metadata",
      track: "internal",
    )
    UI.success "Android metadata uploaded successfully"
  end
end

# ─── Private helpers ───────────────────────────────────────────────────────────

# Regenerate all 240 golden PNGs and organise them for fastlane.
# L8 (belengaz review): use private_lane so it cannot be called directly
# from the command line — it is an internal helper only.
private_lane :_regenerate_screenshots do
  # Gemini MED: use `path:` option instead of `cd ..` so the lane is
  # independent of the directory Fastlane is executed from.
  sh("flutter test --update-goldens test/screenshots/drivers/ --no-pub", path: "..")
  sh("bash scripts/screenshots_to_fastlane.sh", path: "..")
end

# Fail fast if reviewer demo credentials are missing from the environment.
# They are sourced from 1Password ("App Store reviewer" entry) and must be
# exported before running ios_metadata or deliver_dry_run.
private_lane :_require_demo_credentials do
  missing = ["ASC_DEMO_USER", "ASC_DEMO_PASSWORD"].reject { |k| ENV[k] && !ENV[k].empty? }
  unless missing.empty?
    UI.user_error!(
      "Missing required ENV: #{missing.join(", ")}. " \
      "Source from 1Password 'App Store reviewer' before running this lane."
    )
  end
end

# Returns only the demo credentials. Other review_information fields
# (first_name, last_name, phone_number, email_address, notes) are read from
# their individual .txt files under fastlane/metadata/review_information/
# and merged by deliver.
def _demo_review_information
  {
    demo_user: ENV["ASC_DEMO_USER"],
    demo_password: ENV["ASC_DEMO_PASSWORD"],
  }
end
