<?xml version="1.0" encoding="utf-8"?>
<!--
  B-37: Network security config with certificate pinning.
  Pins Supabase, Mollie, and Cloudinary TLS certificates to prevent MITM attacks.

  Supabase and Mollie use Google Trust Services. Cloudinary uses GlobalSign.
  Pins are set on the intermediate CA (most stable) + root CA (backup).
  Pin expiry: 2027-06-01 — rotate before this date.

  Verified 2026-03-25 via: openssl s_client -showcerts -connect <domain>:443
  See: docs/ARCHITECTURE.md §Security, CLAUDE.md §9

  Note: usesCleartextTraffic in AndroidManifest.xml is redundant when
  networkSecurityConfig is present — Android uses this config instead.
  Both are kept for defense-in-depth.

  TODO: Add PostNL/DHL domain pins when B-25/B-26 ship.
  TODO: iOS cert pinning requires TrustKit or custom URLSession delegate (future task).
-->
<network-security-config>
    <!-- Block cleartext (HTTP) traffic globally -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Supabase API + Realtime (*.supabase.co) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">supabase.co</domain>
        <pin-set expiration="2027-06-01">
            <!-- GTS Root R4 (root CA — Supabase chain) -->
            <pin digest="SHA-256">mEflZT5enoR1FuXLgYYGqnVEoZvmf9c2bVBpiOjYQ0c=</pin>
            <!-- WE1 intermediate (Google Trust Services — Supabase issuer) -->
            <pin digest="SHA-256">kIdp6NNEd8wsugYyyIYFsi1ylMCED3hZbSR8ZFsa/A4=</pin>
        </pin-set>
    </domain-config>

    <!-- Mollie Payments API (*.mollie.com) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">mollie.com</domain>
        <pin-set expiration="2027-06-01">
            <!-- GTS Root R1 (root CA — Mollie chain) -->
            <pin digest="SHA-256">hxqRlPTu1bMS/0DITB1SSu0vd4u/8l8TjPgfaAp63Gc=</pin>
            <!-- WR3 intermediate (Google Trust Services — Mollie issuer) -->
            <pin digest="SHA-256">OdSlmQD9NWJh4EbcOHBxkhygPwNSwA9Q91eounfbcoE=</pin>
        </pin-set>
    </domain-config>

    <!-- Cloudinary CDN (res.cloudinary.com — user images) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">cloudinary.com</domain>
        <pin-set expiration="2027-06-01">
            <!-- GlobalSign Atlas R3 DV TLS CA 2025 Q3 (intermediate — Cloudinary issuer) -->
            <pin digest="SHA-256">aI842soAc3qV4KYjwVxZ+diYIoSeeT6G7u9HJ3C4RQQ=</pin>
            <!-- GlobalSign Root CA - R3 (root CA) -->
            <pin digest="SHA-256">cGuxAXyFXFkWm61cF4HPWX8S0srS9j0aSqN0k4AP+4A=</pin>
        </pin-set>
    </domain-config>

    <!-- Debug builds only: allow user-installed CA certs for proxy tools (Charles, mitmproxy) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
